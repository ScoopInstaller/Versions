            "hash": "55910b7b9cc0d7c66ddb4a7504b36e61649a71ca486d9b7b610f61cbf1adb89e"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ade7e27ub2hggwywypa7ixdxzota_152.0.7944.0/152.0.7944.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "9e8ec793855524ecff742d7f9d1709960ec2b237f3faa9449fddeb022e818ff4"
