            "hash": "d353f09139561d758df6615c124684ae87f5802e20a6e9dd9a2d15bc8400f092"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/acqahtzichnqzegjhtblywz75wva_152.0.7932.0/152.0.7932.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "208837048f41bb173ce64e0e9607d9d3e7e4368254a242ac82aae6ec55991eb0"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/b2ufnfa25amysui46654wvjsxy_152.0.7932.0/152.0.7932.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "cc285ecff0321891c297d3d0f5b186d8150b85e7e629557325961d5215849b25"
