        "arm64": {
            "url": "https://dl.google.com/release2/chrome/aci7vcitxl2svd34incqkgtil5ya_152.0.7936.0/152.0.7936.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "81413340434537c3441bb1d3297eee898e396a243955c4ae6b9639b64098c25d"
