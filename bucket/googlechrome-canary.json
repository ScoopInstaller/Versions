            "hash": "aec9b44d7910b958e781ca333064116989a1336152938765717f92affc997bed"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/g36xyh7bnh5vifgvaos6dkcqi4_152.0.7930.0/152.0.7930.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "1cd361477bf964e1c757b14e09cb359b2164d2721d5ce5a9f428244fb676781d"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/k3a4kssbfwm6ohvfc7eaevjpke_152.0.7930.0/152.0.7930.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "97a0cd6f275f255a58ced15099414cd4f89a183491671c59205c2554cae1a487"
