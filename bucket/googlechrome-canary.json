        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acoqsy3lw4jfulpxfjhg73aebdga_152.0.7928.0/152.0.7928.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "6183d27d530fdcfcce05043f505e74b369724642109bca6478a6e85d2c158370"
