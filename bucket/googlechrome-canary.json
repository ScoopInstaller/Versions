            "hash": "fdf43f9b3a86e2e4f2a3aa8bc80126c7b02f98eb512499c46a0da22fcc87d3e4"
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/mywzyug66wz57stgkfi23kowiu_152.0.7947.0/152.0.7947.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "04a0a98fbfb8cf66c15e26285ce6f6750e478a8990ed5c2b11b93af3de53f656"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/ocmoe72jvabrsbczdqsnaewct4_152.0.7947.1/152.0.7947.1_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "305eada6db98ad6cd49522330983198ad5d4923937e486ecfdb9c09cb9ecad91"
