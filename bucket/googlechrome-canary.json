            "hash": "00a2e290b494e2d5bff332f6d133ea269d7caf6a07117e8c9d4f81bbf6cbac42"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/iafxcj325vgxioqpubvj6s43ie_152.0.7955.0/152.0.7955.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "dfc573259d16060929cbfcca62228523e21a1add6b37b96739a6d563327321d6"
