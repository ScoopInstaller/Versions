        "arm64": {
            "url": "https://dl.google.com/release2/chrome/fyjynj4kelwwu6dkhv7wnabsse_152.0.7949.0/152.0.7949.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "910043d3fa5b29680e4f7e30989f18a27b58a20f9446a727bfb1ad2980c7d3cb"
