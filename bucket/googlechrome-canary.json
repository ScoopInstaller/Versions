        "arm64": {
            "url": "https://dl.google.com/release2/chrome/acp33wrmrqf5zyjn7u4gpl5sxwna_152.0.7939.2/152.0.7939.2_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "8077249cef7d7252f112000aff97a11535478cf5a3a2d8fb9e78b04286df54dd"
