        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/iil6yhxbcjnkgscgnznm6i7x6m_152.0.7963.0/152.0.7963.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "d16cf84953b7790bcbba051530d63a05699edf00f4deeb976b41300d389fe137"
        },
        "arm64": {
            "url": "https://dl.google.com/release2/chrome/adqhsrirhpkbmqnh6ftmhg7klj7a_152.0.7963.0/152.0.7963.0_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "760865ae4253f3951118912d302ad5d587711b19fd9b6ebf1f38e128b1efc573"
